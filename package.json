{
  "name": "ai-readable-code-lab",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "phase1-architecture/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "validate": "npm run typecheck && npm run format:check && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "fastify": "^5.4.0"
  }
}
