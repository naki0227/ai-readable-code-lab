#!/usr/bin/env sh
set -eu

if [ "$#" -ne 3 ]; then
  echo "usage: $0 <task-id> <monolithic|layered|feature-based> <result-file>" >&2
  exit 64
fi

task_id=$1
target=$2
result_file=$3

case "$task_id" in
  task-01-category|task-02-completed-assignee|task-03-history|task-04-overdue-bug|task-05-archive|task-06-duplicate) ;;
  *)
    echo "unsupported task: $task_id" >&2
    exit 64
    ;;
esac

case "$target" in
  monolithic|layered|feature-based) ;;
  *)
    echo "unsupported target: $target" >&2
    exit 64
    ;;
esac

test_file="hidden-tests/phase1/${task_id}.test.ts"
if [ ! -f "$test_file" ]; then
  echo "hidden test is unavailable: $test_file" >&2
  exit 66
fi

mkdir -p "$(dirname "$result_file")"
HIDDEN_TEST_TARGET="$target" npx vitest run --config hidden-tests/vitest.config.ts "$test_file" > "$result_file" 2>&1
