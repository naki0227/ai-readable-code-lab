+      { id: '2', taskId: task.id, action: 'UPDATED' },
+      { id: '3', taskId: task.id, action: 'ASSIGNEE_CHANGED' },
+      { id: '4', taskId: task.id, action: 'COMPLETED' },
+    ]);
+    expect(
