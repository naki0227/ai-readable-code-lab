+  it('returns each task operation history in creation order', async () => {
+    const app = buildApp();
+    const task = (
+      await app.inject({ method: 'POST', url: '/tasks', payload: { title: 'Test' } })
+    ).json() as { id: string };
+
+    await app.inject({
+      method: 'PATCH',
+      url: `/tasks/${task.id}`,
+      payload: { title: 'Updated task' },
+    });
+    await app.inject({
+      method: 'PATCH',
+      url: `/tasks/${task.id}`,
+      payload: { assigneeId: 'user-1' },
+    });
