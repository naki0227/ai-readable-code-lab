+export const asResponse = (task: Task) => {
+  const isOverdue =
+    (task.status === 'TODO' || task.status === 'IN_PROGRESS') &&
+    Boolean(task.dueDate) &&
+    (task.dueDate as string) < new Date().toISOString().slice(0, 10);
+
+  return {
+    ...task,
+    isOverdue,
+    warnings: isOverdue ? ['due date is in the past'] : [],
+  };
+};
